# ─── AI Provider ─────────────────────────────────────────────────────────────
# Options: claude | ollama
AI_PROVIDER=claude

# Anthropic — required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama — required when AI_PROVIDER=ollama
# For native Ollama (running on the host): http://host.docker.internal:11434
# For containerized Ollama (docker compose --profile ollama): http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ─── MongoDB (used when running services outside Docker) ──────────────────────
MONGO_URI_BFF=mongodb://localhost:27017/arch-analyzer-bff
MONGO_URI_UPLOAD=mongodb://localhost:27017/arch-analyzer-uploads
MONGO_URI_PROCESSING=mongodb://localhost:27017/arch-analyzer-processing
MONGO_URI_REPORT=mongodb://localhost:27017/arch-analyzer-reports

# ─── Kafka (used when running services outside Docker) ────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── Internal service URLs (Docker uses service names; local dev uses localhost) ─
PROCESSING_SERVICE_URL=http://localhost:3005

# ─── Service ports ───────────────────────────────────────────────────────────
BFF_PORT=3001
UPLOAD_SERVICE_PORT=3002
DIAGRAM_AGENT_PORT=3003
ANALYSIS_AGENT_PORT=3004
PROCESSING_PORT=3005
FRONTEND_PORT=3000
