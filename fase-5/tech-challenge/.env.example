# Anthropic API Key — required for AI agents
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MongoDB
MONGO_URI_BFF=mongodb://mongo:27017/arch-analyzer-bff
MONGO_URI_UPLOAD=mongodb://mongo:27017/arch-analyzer-uploads
MONGO_URI_PROCESSING=mongodb://mongo:27017/arch-analyzer-processing
MONGO_URI_REPORT=mongodb://mongo:27017/arch-analyzer-reports

# Kafka
KAFKA_BROKERS=kafka:9092

# Service ports (host-mapped)
BFF_PORT=3001
UPLOAD_SERVICE_PORT=3002
DIAGRAM_AGENT_PORT=3003
ANALYSIS_AGENT_PORT=3004
FRONTEND_PORT=3000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1